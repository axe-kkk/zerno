# Database
# Локально (python run.py на хості): host localhost, порт 5432, БД zerno_db.
# У Docker Compose: якщо рядок DATABASE_URL взагалі не задати, docker-compose підставить postgresql://USER:PASS@db:5432/zerno_db (хост db — ім'я сервісу).
# Якщо задаєте DATABASE_URL самі для контейнера бекенда — обов'язково хост db, не localhost.
DATABASE_URL=postgresql://user:password@localhost:5432/zerno_db

# PostgreSQL (для сервісу db у docker-compose; ті самі user/password підуть у дефолтний DATABASE_URL бекенда)
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# App
APP_NAME=Zerno Web3 App
DEBUG=True
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Server
HOST=0.0.0.0
PORT=8000

# Super Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Super Admin

